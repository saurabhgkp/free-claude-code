# ── Required ─────────────────────────────────────────────────────────────────

# NVIDIA NIM API key  →  https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-...

# Model to use (provider/model format)
MODEL=nvidia_nim/meta/llama3-70b-instruct

# Telegram bot token  →  @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# Your Telegram user ID  →  @userinfobot on Telegram
ALLOWED_TELEGRAM_USER_ID=your-numeric-user-id

# ── Everything else has a sensible default and can be left unset ──────────────
# See config/settings.py for all available options.
